# Normalize line endings to LF for all text files (abapGit + tooling expect LF)
* text=auto eol=lf
*.abap text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.md text eol=lf
*.mjs text eol=lf
*.js text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.css text eol=lf
*.properties text eol=lf

# Binary sample assets under ui5/ — leave untouched
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.pdf binary
